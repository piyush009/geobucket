# Where form submissions are delivered
CONTACT_TO=piyush.tiwary@geobucket.in

# --- Option A (recommended on AWS EC2): Resend ---
# https://resend.com → API Keys → create key
# RESEND_API_KEY=re_xxxxxxxx
# Verify geobucket.in domain in Resend, then set:
# RESEND_FROM="GeoBucket <hello@geobucket.in>"
# Until domain is verified you can test with:
# RESEND_FROM="GeoBucket <onboarding@resend.dev>"

# --- Option B: GoDaddy SMTP (often blocked from AWS) ---
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=piyush.tiwary@geobucket.in
SMTP_PASS=your-email-password
SMTP_FROM="GeoBucket Website <piyush.tiwary@geobucket.in>"
